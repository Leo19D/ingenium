# =============================================================================
# AI Quote & Procurement Platform — Environment Variables Template
# =============================================================================
# Copy to .env and fill in. Never commit .env to git.

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
ENV=development                          # development | staging | production
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change_me_to_a_random_64_char_string
TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
API_V1_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=quote_platform
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/quote_platform

# -----------------------------------------------------------------------------
# Redis (cache + Celery broker)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# Object Storage (S3 / MinIO / R2)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000        # leave blank for AWS S3
S3_BUCKET=quote-platform-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false                     # true in production with real S3/R2

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic                # anthropic | openai | local
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-5
ANTHROPIC_MODEL_REASONING=claude-opus-4-7

OPENAI_API_KEY=sk-...                # optional fallback
OPENAI_MODEL_DEFAULT=gpt-4o

# Embeddings
EMBEDDING_PROVIDER=openai             # openai | voyage | local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# -----------------------------------------------------------------------------
# OCR / Document AI
# -----------------------------------------------------------------------------
OCR_PROVIDER=azure                    # azure | aws | google | local
AZURE_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_DI_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Authentication (choose one)
# -----------------------------------------------------------------------------
AUTH_PROVIDER=local                   # local | clerk | auth0
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# JWT (for local auth)
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=smtp                   # smtp | sendgrid | postmark | ses
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# -----------------------------------------------------------------------------
# FX Rates
# -----------------------------------------------------------------------------
FX_PROVIDER=ecb                       # ecb | openexchangerates | manual
OPENEXCHANGERATES_APP_ID=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=true

# -----------------------------------------------------------------------------
# Frontend (Next.js — prefix with NEXT_PUBLIC_ for client-side)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="AI Quote Platform"
NEXT_PUBLIC_DEFAULT_LOCALE=en
